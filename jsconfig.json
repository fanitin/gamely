{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "module": "ESNext",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "target": "ESNext"
    },
    "include": [
        "resources/js/**/*"
    ],
    "exclude": [
        "node_modules",
        "vendor",
        "public"
    ]
}
